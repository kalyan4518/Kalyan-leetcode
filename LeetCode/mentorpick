 import java.util.*;
class BeingZero {
    public List<Integer> solve(int[] a, int n)
    {
        List<Integer> ans = new ArrayList<>();
        HashSet<Integer> s = new HashSet<>();
        for(int i = 0; i < n; i++)
        {
            s.add(a[i]);
        }
        for(int c : s)
        {
            if(c > 0 && s.contains(-c))
            {
                ans.add(c);
            }
        }
        Collections.sort(ans);  
        return ans;
    }
}
